# ---------------------------------------------------------------------------
# server environment
# Copy to `.env` and fill in. `.env` is gitignored.
# ---------------------------------------------------------------------------

# Database — either set DATABASE_URL directly, or the POSTGRES_* parts below.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/drive-thru-agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=drive-thru-agent

# Bootstrap admin — if both are set, an admin user is seeded on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# CORS — comma-separated origins allowed to call the API (the React client).
CORS_ORIGINS=http://localhost:5173

# HTTP bind
HOST=0.0.0.0
PORT=8000

# Document-parsing provider keys. The admin picks which provider/model parses
# uploaded menus (see /api/v1/parser-config); set the key for whichever is used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# LiveKit — used to mint customer connection tokens (POST /api/v1/connection).
# Same project/credentials the voice-agent uses.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
