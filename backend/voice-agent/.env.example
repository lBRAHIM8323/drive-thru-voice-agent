# ---------------------------------------------------------------------------
# voice-agent environment
# Copy to `.env` and fill in. `.env` is gitignored.
# ---------------------------------------------------------------------------

# LiveKit connection (required) — from your LiveKit Cloud project or self-host.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider API keys.
# The agent builds its STT/LLM/TTS from LiveKit provider plugins. The frontend
# only picks the provider + model + non-secret params; the secret keys live here
# on the agent host. Set the keys for whichever providers you actually select.
# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# STT
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
# TTS
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# Shared secret to authenticate against the server API (for PATCH sessions etc).
AGENT_API_KEY=

# Config service — where the agent fetches the per-session AgentConfig.
# The dispatch/room metadata carries {"config_id": "..."} and the agent calls
# GET {SERVER_URL}/api/v1/agent-configs/{config_id}. If unset or unreachable,
# the agent falls back to its built-in default config.
SERVER_URL=http://localhost:8000

# Menu data source (used once the server-managed menu DB is wired up).
# The voice-agent reads the menu that backend/server administers.
# DATABASE_URL=
